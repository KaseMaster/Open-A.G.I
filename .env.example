# AEGIS Framework - Environment Configuration
# This file contains configuration for Docker services

# ============================================================================
# Grafana Configuration
# ============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=aegis2024
GRAFANA_ROOT_URL=http://localhost:3000

# ============================================================================
# Important Notes
# ============================================================================
# 1. Grafana credentials (GRAFANA_ADMIN_USER and GRAFANA_ADMIN_PASSWORD) 
#    ONLY work during initial container setup. 
#
# 2. Once Grafana database is created, these environment variables are ignored.
#
# 3. To change credentials after first deployment, use one of these methods:
#    - grafana-cli: docker exec aegis-grafana grafana cli admin reset-admin-password <newpass>
#    - Grafana UI: Profile > Change Password
#    - Remove volume and recreate: docker volume rm open-agi_grafana-data && docker-compose up -d grafana
#
# 4. DO NOT commit this file with real passwords in production!
# ============================================================================
